# CalNexus environment variables
#
# CalNexus is a command-line math expression evaluator with no network
# functionality, so configuration is minimal. All variables are OPTIONAL and
# have sensible defaults — you do not need this file to run the tool.
#
# Copy this file to `.env` and adjust values as needed:
#   cp .env.example .env

# Logging level for the `tracing`/`log` subsystem.
# One of: error, warn, info, debug, trace
# Default: info
RUST_LOG=info

# Capacity of the L1 evaluation cache (number of cached expression results).
# Set to 0 to disable caching. Larger values trade memory for hit rate.
# Default: 10000
CALNEXUS_CACHE_SIZE=10000
