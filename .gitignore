# =============================================================================
# Rust build artifacts
# =============================================================================
/target
**/*.rs.bk
# NOTE: Cargo.lock is intentionally tracked for this binary crate.
# Do NOT ignore Cargo.lock — it locks dependencies for reproducible builds.

# =============================================================================
# IDE / editor files
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store
/.trae

# =============================================================================
# Python virtual environment
# =============================================================================
/.venv
__pycache__/

# =============================================================================
# Coverage / test artifacts
# =============================================================================
*.profraw
tarpaulin-report.html
lcov*.info
cobertura.xml

# =============================================================================
# Environment files
# =============================================================================
.env
# .env.example stays tracked as a template — do not ignore it.

# =============================================================================
# OS files
# =============================================================================
Thumbs.db
Desktop.ini

# =============================================================================
# Project-specific
# =============================================================================
# openspec workflow directory
/openspec
# specmark workflow directory (rule 30: never commit specmark/)
/specmark
**/specmark/
# codenexus knowledge graph DB (runtime artifact, not source)
.codenexus/
# runtime logs
/logs
# reference templates
temp/
# spec source docs
docs/ADD.md
docs/PRD.md
docs/TEST.md
